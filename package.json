{
  "name": "nano",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "deploy:full": "bash scripts/deploy.sh",
    "db:local": "wrangler d1 execute harness-db --local --file=schema.sql && wrangler d1 execute harness-db --local --file=migrations/002_github.sql || true",
    "db:migrate": "wrangler d1 execute harness-db --file=schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.0.0"
  }
}
